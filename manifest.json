{
  "manifest_version": 3,
  "name": "SyncTime",
  "version": "2.0.0",
  "description": "World clock & timezone converter. See who's awake, convert meeting times, copy across your team.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SyncTime",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "alarms"
  ]
}
